{
  "name": "agentlens",
  "displayName": "AgentLens",
  "description": "AI Agent Debugger for VS Code — real-time execution visibility for AI agents",
  "version": "0.1.0",
  "publisher": "agentlens",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentlens/agentlens"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "debugger",
    "llm",
    "observability"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentlens",
          "title": "AgentLens",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agentlens": [
        {
          "id": "agentlens.status",
          "name": "Connection",
          "type": "tree"
        },
        {
          "id": "agentlens.currentState",
          "name": "Current State",
          "type": "tree"
        },
        {
          "id": "agentlens.metrics",
          "name": "Live Metrics",
          "type": "tree"
        },
        {
          "id": "agentlens.sessions",
          "name": "Debug Sessions",
          "type": "tree"
        },
        {
          "id": "agentlens.executionTree",
          "name": "Execution Tree",
          "type": "tree"
        },
        {
          "id": "agentlens.inspector",
          "name": "Inspector",
          "type": "webview"
        },
        {
          "id": "agentlens.context",
          "name": "Context",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "agentlens.selectSession",
        "title": "Select Session",
        "category": "AgentLens"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.95.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
